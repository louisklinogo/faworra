{
  "name": "Faworra",
  "private": true,
  "packageManager": "bun@latest",
  "workspaces": [
    "apps/dashboard",
    "apps/api",
    "apps/worker",
    "apps/website",
    "apps/realtime",
    "packages/*",
    "packages/cache"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:dashboard\" \"bun run dev:realtime\" \"bun run dev:worker\"",
    "dev:logged": "concurrently --raw \"bun run dev:api 2>&1 | tee logs/api.log\" \"bun run dev:dashboard 2>&1 | tee logs/admin.log\" \"bun run dev:realtime 2>&1 | tee logs/realtime.log\"",
    "dev:api": "bun --hot apps/api/src/index.ts",
    "dev:realtime": "bun --hot apps/realtime/src/index.ts",
    "dev:worker": "bun --hot apps/worker/src/index.ts",
    "dev:doppler": "doppler run -- bun run dev",
    "dev:api:doppler": "doppler run -- bun run dev:api",
    "dev:realtime:doppler": "doppler run -- bun run dev:realtime",
    "dev:worker:doppler": "doppler run -- bun run dev:worker",
    "dev:dashboard": "cd apps/dashboard && bun run dev",
    "dev:jobs": "cd packages/jobs && bun run dev",
    "jobs:deploy": "cd packages/jobs && bun run deploy",
    "dev:website": "cd apps/website && bun run dev",
    "logs:tail": "tail -f logs/api.log logs/admin.log",
    "build:dashboard": "cd apps/dashboard && bun run build",
    "build:api": "cd apps/api && bun run build",
    "build:website": "cd apps/website && bun run build",
    "check": "bunx ultracite check apps packages drizzle",
    "fix": "bunx ultracite fix apps packages drizzle",
    "lint": "bun run check",
    "format": "bun run fix",
    "typecheck": "bun run typecheck:dashboard && bun run typecheck:api && bun run typecheck:website && bun run typecheck:worker",
    "typecheck:dashboard": "cd apps/dashboard && bunx --bun tsc --noEmit",
    "typecheck:api": "cd apps/api && bunx --bun tsc --noEmit",
    "typecheck:website": "cd apps/website && bunx --bun tsc --noEmit",
    "typecheck:worker": "cd apps/worker && bunx --bun tsc --noEmit",
    "env:validate": "bun scripts/env-validate.ts",
    "verify:rls": "bun scripts/verify-rls.ts",
    "db:types": "supabase gen types typescript --project-id zvatkstmsyuytbajzuvn > packages/supabase/src/types/database.generated.ts",
    "db:types:generated": "supabase gen types typescript --project-id zvatkstmsyuytbajzuvn > packages/supabase/src/types/database.generated.ts",
    "db:pull": "bunx --bun drizzle-kit introspect --config=drizzle.config.ts",
    "db:check": "bunx --bun drizzle-kit check --config=drizzle.config.ts",
    "env:api": "bun scripts/copy-env-to-api.ts",
    "prepare": "husky",
    "test": "bun test tests/webhooks --bail"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.8",
    "chroma-js": "^3.1.2",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.5",
    "libphonenumber-js": "^1.12.24",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "pino-pretty": "^13.1.2",
    "postgres": "^3.4.7",
    "react-dropzone": "^14.3.8",
    "react-hotkeys-hook": "^5.1.0",
    "usehooks-ts": "^3.1.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "concurrently": "^9.2.1",
    "culori": "3.3.0",
    "husky": "^9.1.6",
    "supabase": "^2.53.6",
    "ultracite": "latest",
    "typescript": "^5"
  }
}