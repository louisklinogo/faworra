{
  "name": "Faworra",
  "private": true,
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/dashboard",
    "apps/api",
    "apps/worker",
    "apps/website",
    "apps/realtime",
    "packages/*",
    "packages/cache"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:logged": "concurrently --raw \"bun run dev:api 2>&1 | tee logs/api.log\" \"bun run dev:dashboard 2>&1 | tee logs/admin.log\" \"bun run dev:realtime 2>&1 | tee logs/realtime.log\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "fix": "turbo run fix",
    "env:validate": "bun scripts/env-validate.ts",
    "verify:rls": "bun scripts/verify-rls.ts",
    "db:types": "supabase gen types typescript --project-id zvatkstmsyuytbajzuvn > packages/supabase/src/types/database.generated.ts",
    "db:types:generated": "supabase gen types typescript --project-id zvatkstmsyuytbajzuvn > packages/supabase/src/types/database.generated.ts",
    "db:pull": "bunx --bun drizzle-kit introspect --config=drizzle.config.ts",
    "db:check": "bunx --bun drizzle-kit check --config=drizzle.config.ts",
    "env:api": "bun scripts/copy-env-to-api.ts",
    "prepare": "husky",
    "test": "bun test tests/webhooks --bail"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.8",
    "chroma-js": "^3.1.2",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.5",
    "libphonenumber-js": "^1.12.24",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "pino-pretty": "^13.1.2",
    "postgres": "^3.4.7",
    "react-dropzone": "^14.3.8",
    "react-hotkeys-hook": "^5.1.0",
    "usehooks-ts": "^3.1.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "concurrently": "^9.2.1",
    "culori": "3.3.0",
    "husky": "^9.1.6",
    "styled-jsx": "^5.1.7",
    "supabase": "^2.53.6",
    "turbo": "^2.6.1",
    "typescript": "^5",
    "ultracite": "latest"
  }
}