# Dashboard — Environment Template

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public app URL (optional; some links use it)
NEXT_PUBLIC_URL=http://localhost:3000

# AI SDK (CSV field mapping)
GOOGLE_GENERATIVE_AI_API_KEY=

# Trigger.dev (not required client-side; included for parity)
TRIGGER_PROJECT_ID=

# If your API is on a separate origin, uncomment and set this
# NEXT_PUBLIC_API_URL=http://localhost:3001
