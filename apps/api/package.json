{
  "name": "api",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
    "dev": "bun ../../scripts/run-dev-with-portless.mjs api",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@faworra-new/api": "workspace:*",
    "@faworra-new/auth": "workspace:*",
    "@faworra-new/db": "workspace:*",
    "@faworra-new/env": "workspace:*",
    "@faworra-new/jobs": "workspace:*",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "catalog:",
    "@trigger.dev/sdk": "4.4.3",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faworra-new/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
