{
	"extends": "@faworra-new/config/tsconfig.base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "react-jsx",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"paths": {
			"@faworra-new/ui/*": ["./src/*"]
		},
		"strictNullChecks": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules"]
}
