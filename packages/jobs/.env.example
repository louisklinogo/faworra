# Jobs Worker — Environment Template

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=

# Trigger.dev (required for dev/production workers)
TRIGGER_PROJECT_ID=
TRIGGER_API_KEY=
# or TRIGGER_SECRET_KEY= (older naming)
TRIGGER_ENVIRONMENT=development

# AI SDK (CSV processing, embeddings, etc.)
GOOGLE_GENERATIVE_AI_API_KEY=
